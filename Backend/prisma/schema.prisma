generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Speaker {
  id        String   @id @default(uuid())
  fullName  String   @map("full_name")
  photoUrl  String?  @map("photo_url")
  bio       String?
  twitter   String?
  linkedin  String?
  website   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions SessionSpeaker[]

  @@map("speakers")
}

model Room {
  id        String   @id @default(uuid())
  name      String
  capacity  Int?
  createdAt DateTime @default(now()) @map("created_at")

  sessions Session[]

  @@map("rooms")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  location    String?
  coverColor  String?  @default("from-primary to-accent") @map("cover_color")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sessions Session[]

  @@map("events")
}

model Session {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  roomId      String?  @map("room_id")
  title       String
  description String?
  track       String?
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  capacity    Int?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  room      Room?            @relation(fields: [roomId], references: [id], onDelete: SetNull)
  speakers  SessionSpeaker[]
  questions Question[]
  favorites Favorite[]

  @@index([eventId])
  @@index([roomId])
  @@index([startTime])
  @@map("sessions")
}

model SessionSpeaker {
  sessionId String @map("session_id")
  speakerId String @map("speaker_id")
  sortOrder Int    @default(0) @map("sort_order")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@id([sessionId, speakerId])
  @@index([speakerId])
  @@map("session_speakers")
}

model Question {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  content    String
  authorName String?  @map("author_name")
  upvotes    Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("questions")
}

model Favorite {
  userToken String   @map("user_token")
  sessionId String   @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([userToken, sessionId])
  @@map("favorites")
}
